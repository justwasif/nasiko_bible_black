# ── LLM Provider Keys (stored ONLY in gateway — never in agent code) ──────────
# At least ONE of Gemini or Groq is required (both are free tier)
GEMINI_API_KEY=your-gemini-key-here          # free at aistudio.google.com/apikey
GROQ_API_KEY=your-groq-key-here              # free at console.groq.com

# Optional paid providers
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ── Gateway Auth ───────────────────────────────────────────────────────────────
# Set this to any random string — used to generate virtual keys
LITELLM_MASTER_KEY=sk-litellm-master-changeme-use-any-random-string

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=litellm-local-password
DATABASE_URL=postgresql://litellm:litellm-local-password@postgres:5432/litellm

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Agent Config (fill in AFTER running make generate-key) ────────────────────
GATEWAY_URL=http://localhost:4000
GATEWAY_VIRTUAL_KEY=sk-litellm-v1-fill-in-after-generate-key

# ── OpenTelemetry (optional) ──────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=litellm-gateway
